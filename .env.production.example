# Template for a real deployment. Copy to .env on the server and fill in
# real values.
#
# ENVIRONMENT=production changes app behavior (see app/auth.py, app/main.py):
#   - Refuses to start if SECRET_KEY is unset (no insecure dev fallback).
#   - Marks the bookr_token auth cookie Secure — it will NOT be sent over
#     plain HTTP, so the app MUST sit behind TLS (e.g. a reverse proxy
#     terminating HTTPS) before you deploy with this file.

DATABASE_URL=postgresql+asyncpg://<user>:<password>@db:5432/compliance_db
REDIS_URL=redis://cache:6379/0

# Required — startup fails without it when ENVIRONMENT=production.
SECRET_KEY=

# Required to use /auth/emergency-reset. Leave blank to disable that endpoint.
MASTER_RESET_KEY=

ENVIRONMENT=production

# Comma-separated list of the real origin(s) serving the frontend.
ALLOWED_ORIGINS=https://your-domain.example.com

# Keep SQL query logging off in production.
SQL_ECHO=false