# Copy this file to .env, fill in real values, then run `docker-compose up`.
# This is the LOCAL DEVELOPMENT template — it deliberately leaves ENVIRONMENT
# at its default so cookie auth works over plain http://localhost:8000.
# Deploying somewhere real? Use .env.production.example instead.

# Database Configuration
DATABASE_URL=postgresql+asyncpg://user:pass@db:5432/compliance_db

# Cache Configuration
REDIS_URL=redis://cache:6379/0

# Security
# Generate a random secret: openssl rand -hex 32
SECRET_KEY=

# Required to reset the admin password via /auth/emergency-reset.
# Leave blank to disable that endpoint.
MASTER_RESET_KEY=

# development (default) | production — see .env.production.example
ENVIRONMENT=development